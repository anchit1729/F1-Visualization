{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f1-replay.local/schemas/catalog.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "replays"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "replays": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "schemaVersion",
          "title",
          "subtitle",
          "season",
          "meetingName",
          "sessionName",
          "replayScope",
          "durationMs",
          "startTimeMs",
          "endTimeMs",
          "driverCount",
          "trackPreview",
          "bundle",
          "provenance"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "schemaVersion": { "const": 1 },
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": "string", "minLength": 1 },
          "season": { "type": "integer", "minimum": 1950 },
          "meetingName": { "type": "string", "minLength": 1 },
          "sessionName": { "type": "string", "minLength": 1 },
          "replayScope": { "enum": ["race", "lap"] },
          "durationMs": { "type": "integer", "minimum": 1 },
          "startTimeMs": { "type": "integer", "minimum": 0 },
          "endTimeMs": { "type": "integer", "minimum": 0 },
          "driverCount": { "type": "integer", "minimum": 1 },
          "trackPreview": { "$ref": "common.schema.json#/$defs/trackGeometry" },
          "bundle": {
            "type": "object",
            "additionalProperties": false,
            "required": ["indexUrl", "byteSize", "sha256"],
            "properties": {
              "indexUrl": { "type": "string", "minLength": 1 },
              "byteSize": { "type": "integer", "minimum": 1 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          },
          "provenance": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/provenance" }
          }
        }
      }
    }
  }
}
