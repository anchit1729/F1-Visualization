{
  "name": "@f1/replay",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "export:web": "expo export --platform web",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "start": "expo start --dev-client",
